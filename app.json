{
  "expo": {
    "name": "hangout",
    "slug": "hangout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-light-icon.png",
    "scheme": "hangout",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "0.0.1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "x0.x0.x1"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ios-light-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fef9e7",
          "dark": {
            "backgroundColor": "#1c1022"
          }
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "829e5072-86fb-4b84-bfa0-9ef9ea27e4a4"
      }
    }
  }
}
